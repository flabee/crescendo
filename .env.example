# Spotify app credentials (create at https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must exactly match a Redirect URI in your Spotify app settings. NOTE: Spotify
# no longer accepts "localhost" — use the loopback IP 127.0.0.1 for local dev,
# and browse the app at http://127.0.0.1:3000 (not localhost) so the callback host matches:
#   http://127.0.0.1:3000/api/auth/callback/spotify  (local)
#   https://<your-app>.vercel.app/api/auth/callback/spotify  (prod)
NEXTAUTH_URL=http://127.0.0.1:3000
AUTH_URL=http://127.0.0.1:3000
AUTH_TRUST_HOST=true
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Optional BPM fallback source (https://getsongbpm.com/api). Requires a footer backlink.
GETSONGBPM_API_KEY=

# Optional: widen the similar-artist graph with Last.fm (https://www.last.fm/api).
# Without it, Deezer related-artists still provides the graph (zero-config).
LASTFM_API_KEY=

# Optional persistent cache + history (Vercel KV / Upstash). Omit to run in-memory.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Required for /api/similarity (audio-embedding similarity). Supabase project
# with the pgvector extension enabled (see supabase/migrations). Use the
# service role key — the embeddings cache is server-only and bypasses RLS.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Required for /api/similarity. URL of the deployed audio-embedding model
# (laion/larger_clap_music). Defaults to a Hugging Face Inference Endpoint URL
# (https://<endpoint-name>.<region>.aws.endpoints.huggingface.cloud); a
# self-hosted equivalent (e.g. Modal) works too as long as it accepts the same
# request/response shape — see README "Audio-embedding similarity".
EMBEDDING_ENDPOINT_URL=
# Required for /api/similarity. Bearer token for the endpoint above (HF token
# with Inference Endpoint access, or your self-hosted service's token).
EMBEDDING_API_TOKEN=
